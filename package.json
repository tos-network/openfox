{
  "name": "@openfox/openfox",
  "version": "0.2.1",
  "description": "OpenFox - Local Sovereign AI Agent Runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config.js": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./identity/wallet.js": {
      "types": "./dist/identity/wallet.d.ts",
      "default": "./dist/identity/wallet.js"
    },
    "./state/database.js": {
      "types": "./dist/state/database.d.ts",
      "default": "./dist/state/database.js"
    },
    "./tos/address.js": {
      "types": "./dist/tos/address.d.ts",
      "default": "./dist/tos/address.js"
    },
    "./tos/client.js": {
      "types": "./dist/tos/client.d.ts",
      "default": "./dist/tos/client.js"
    },
    "./agent-discovery/card.js": {
      "types": "./dist/agent-discovery/card.d.ts",
      "default": "./dist/agent-discovery/card.js"
    },
    "./agent-discovery/client.js": {
      "types": "./dist/agent-discovery/client.d.ts",
      "default": "./dist/agent-discovery/client.js"
    }
  },
  "bin": {
    "openfox": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tos-network/openfox.git"
  },
  "homepage": "https://github.com/tos-network/openfox",
  "keywords": [
    "openfox",
    "autonomous-agent",
    "sovereign-ai",
    "agent-runtime",
    "self-replicating"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "tsc && pnpm -r build",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run --grep 'security|injection|policy'",
    "test:financial": "vitest run --grep 'financial|spend|treasury'",
    "test:ci": "vitest run --reporter=verbose",
    "clean": "rm -rf dist && pnpm -r clean"
  },
  "dependencies": {
    "@noble/secp256k1": "^2.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "cron-parser": "^4.9.0",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.24.0",
    "ora": "^8.0.0",
    "simple-git": "^3.24.0",
    "siwe": "^2.3.0",
    "ulid": "^2.3.0",
    "viem": "^2.44.2",
    "ws": "^8.19.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
